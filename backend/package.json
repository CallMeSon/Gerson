{
  "name": "gerson-portfolio-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend for Gerson Portfolio Web using Express, PostgreSQL, and Raw SQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node --watch --no-warnings --loader ts-node/esm src/index.ts",
    "build": "rimraf dist && tsc",
    "start": "node dist/index.js",
    "db:migrate": "node --no-warnings --loader ts-node/esm src/db/migrate.ts",
    "db:migrate:prod": "node dist/db/migrate.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.5",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pg": "^8.11.5",
    "@types/uuid": "^9.0.7",
    "rimraf": "^5.0.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
